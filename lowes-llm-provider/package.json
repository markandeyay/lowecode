{
  "name": "lowes-llm-provider",
  "version": "1.0.0",
  "description": "OpenAI-compatible local adapter for Lowe's Mylow chatbot (LOWECODE)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "ts-node-dev --respawn src/index.ts",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "optionalDependencies": {
    "playwright": "^1.61.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3"
  }
}
