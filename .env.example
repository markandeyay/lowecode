LOWECODE_ADAPTER_PORT=3000
LOWES_MYLOW_BASE_URL=http://localhost:3000/v1
LOWES_MYLOW_API_KEY=lowecode-local
# Set to an authorized Lowe's Mylow endpoint to enable live routing.
# Transport is auto-detected:
#   - ending in /v1 or containing /chat/completions → external-openai (OpenAI-compatible)
#   - any other URL → rest (POST { "prompt": "..." }, expects { "response": "..." })
LOWES_MYLOW_LIVE_ENDPOINT=
LOWECODE_MOCK=1
LOWECODE_LOG_LEVEL=info
LOWECODE_DEBUG_TRANSCRIPTS=0
# Browser mode (experimental): opens a visible browser for the user to interact with Mylow
LOWECODE_BROWSER_MODE=0
LOWECODE_BROWSER_PROFILE_DIR=.lowecode-browser-profile
LOWECODE_MYLOW_URL=https://www.lowes.com/l/about/ai-at-lowes
LOWECODE_BROWSER_HEADLESS=0
LOWECODE_BROWSER_TIMEOUT_MS=60000
